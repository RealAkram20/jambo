# =============================================================================
# Jambo — Production .env Template
# =============================================================================
# Copy this to `.env` on the VPS and fill in every placeholder marked with
# < CHANGE_ME >. Never commit a real .env. After editing:
#   php artisan key:generate           # only if APP_KEY is blank
#   php artisan config:clear
#   php artisan config:cache
# =============================================================================

APP_NAME=Jambo
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://< CHANGE_ME: your-domain.com >

# Seed/demo flags MUST be false in production — these generate fake users
# and demo content that should never reach real users.
IS_DUMMY_DATA=false
IS_FAKE_DATA=false
IS_DUMMY_DATA_IMAGE=false
AVATAR_BASE_PATH=/images/avatars/

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=< CHANGE_ME: jambo >
DB_USERNAME=< CHANGE_ME >
DB_PASSWORD=< CHANGE_ME: strong-random-password >

# -----------------------------------------------------------------------------
# Session / cookies (HTTPS)
# -----------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# -----------------------------------------------------------------------------
# Cache / queue / filesystem
# -----------------------------------------------------------------------------
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local

# database queue — contact form emails and any async work go through the
# `jobs` table (created by 2026_04_15_015318_create_jobs_table migration).
# Requires a queue worker running via supervisor:
#   php artisan queue:work --tries=3 --timeout=60
QUEUE_CONNECTION=database

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail (contact form, password resets, email verification, 2FA backup codes)
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=< CHANGE_ME: smtp.hostinger.com | smtp.sendgrid.net | ... >
MAIL_PORT=587
MAIL_USERNAME=< CHANGE_ME >
MAIL_PASSWORD=< CHANGE_ME >
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@< CHANGE_ME: your-domain.com >"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# PesaPal (default payment gateway)
# -----------------------------------------------------------------------------
JAMBO_DEFAULT_GATEWAY=pesapal
JAMBO_CURRENCY=UGX
PESAPAL_VERIFY_SSL=true
# Leave blank to use APP_URL for callbacks. Only override if APP_URL isn't
# reachable from PesaPal's servers (rare on a real VPS).
PESAPAL_CALLBACK_BASE_URL=
# Consumer key/secret and the live/sandbox toggle are admin-edited in
# /dashboard/payments — they live in the `settings` table, not here.

# -----------------------------------------------------------------------------
# S3 media (only if using FILESYSTEM_DISK=s3; leave blank if staying local)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Pusher (only if you enable BROADCAST_DRIVER=pusher; default `log` needs none)
# -----------------------------------------------------------------------------
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# -----------------------------------------------------------------------------
# Web Push (browser notifications) — generate once, reuse across deploys
# -----------------------------------------------------------------------------
VAPID_SUBJECT=mailto:admin@< CHANGE_ME: your-domain.com >
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_PEM_FILE=

# -----------------------------------------------------------------------------
# Social login (optional — the blade only renders buttons when ACTIVE=true)
# -----------------------------------------------------------------------------
GOOGLE_ACTIVE=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=/auth/google/callback

FACEBOOK_ACTIVE=false
GITHUB_ACTIVE=false

# -----------------------------------------------------------------------------
# Vite (build-time, inherited from APP_NAME / PUSHER_*)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
