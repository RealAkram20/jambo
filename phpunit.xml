<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
            <directory>Modules/*/tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <!-- Strip the /Jambo subdirectory from APP_URL during tests.
             Apache's .htaccess rewrites /Jambo/... → / in production,
             but the test HTTP kernel has no such rewrite, so routes
             registered as `streams/limit` wouldn't match requests
             against `/Jambo/streams/limit`. -->
        <env name="APP_URL" value="http://localhost"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_DRIVER" value="array"/>
        <!-- Isolate tests from the dev MySQL — RefreshDatabase calls migrate:fresh
             once per suite, which would otherwise wipe the dev demo data. -->
        <env name="DB_CONNECTION" value="sqlite"/>
        <env name="DB_DATABASE" value=":memory:"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <!-- `array` resets the session on every request, which breaks
             tests that capture session()->getId() in setup and then
             reference it in a follow-up HTTP call (device-limit tests
             need this to simulate "the same browser" across requests).
             `file` persists inside the single test runner lifecycle. -->
        <env name="SESSION_DRIVER" value="file"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
    </php>
</phpunit>
